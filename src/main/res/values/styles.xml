<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- MaterialTimePicker Theme -->
    <style name="TrpCustomTimePickerTheme" parent="ThemeOverlay.MaterialComponents.TimePicker">
        <!-- Selected time field background + Clock hand (text primary #333333) -->
        <item name="colorPrimary">@color/trp_text_primary</item>

        <!-- Selected time text - beyaz (dark background üzerinde) -->
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Unselected time field text + Clock dial numbers (dark #333333) -->
        <item name="colorOnSurface">@color/trp_text_primary</item>

        <!-- AM/PM chip background (açık gri #F7F7F7) -->
        <item name="chipBackgroundColor">@color/trp_bgCloudy</item>

        <!-- Surface/Dialog background (beyaz) -->
        <item name="colorSurface">@android:color/white</item>

        <!-- Clock dial background (açık gri) -->
        <item name="colorOnSecondary">@color/trp_bgCloudy</item>

        <!-- Button styles -->
        <item name="materialButtonOutlinedStyle">@style/TrpTimePickerCancelButton</item>
        <item name="buttonBarPositiveButtonStyle">@style/TrpTimePickerConfirmButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/TrpTimePickerCancelButton</item>
    </style>

    <!-- Confirm/OK button (pink filled) -->
    <style name="TrpTimePickerConfirmButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/trp_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/medium</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Cancel button (text button) -->
    <style name="TrpTimePickerCancelButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/trp_text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/medium</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
