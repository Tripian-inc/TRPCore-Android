<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/llDayContainer"
    android:layout_width="50dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_day_filter_unselected">

    <!-- Day letter (e.g., "M" for Monday) -->
    <TextView
        android:id="@+id/tvDayLetter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:padding="0dp"
        android:includeFontPadding="false"
        android:fontFamily="@font/medium"
        android:textSize="12sp"
        android:textColor="@color/trp_text_primary"
        tools:text="M" />

    <!-- Day number (e.g., "13") -->
    <TextView
        android:id="@+id/tvDayNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:padding="0dp"
        android:includeFontPadding="false"
        android:fontFamily="@font/bold"
        android:textSize="16sp"
        android:textColor="@color/trp_text_primary"
        tools:text="13" />

    <!-- Month abbreviation (e.g., "May") -->
    <TextView
        android:id="@+id/tvMonth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:padding="0dp"
        android:includeFontPadding="false"
        android:fontFamily="@font/medium"
        android:textSize="14sp"
        android:textColor="@color/trp_text_primary"
        tools:text="May" />

</LinearLayout>
